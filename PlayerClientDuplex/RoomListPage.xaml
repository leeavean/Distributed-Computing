<Page x:Class="PlayerClientDuplex.RoomListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PlayerClientDuplex"
      mc:Ignorable="d" 
      Title="Rooms" Height="650" Width="450">

    <StackPanel Margin="20">

        <!-- Back button -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Logout" Width="60" Height="30" Click="btnLogout_Click"/>
        </StackPanel>

        <TextBlock Text="Available Rooms" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <ListBox x:Name="lstRooms" DisplayMemberPath="RoomName" Height="200" Margin="0,0,0,10"
                 SelectionChanged="lstRooms_SelectionChanged"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtNewRoom" Width="200" Height="30"/>
            <Button Content="Create" Click="btnCreateRoom_Click" Width="80" Height="30" Margin="6,0,0,0"/>
        </StackPanel>

        <Button x:Name="btnJoinRoom" Content="Join Selected Room" Height="30" Width="200" 
                IsEnabled="False" Click="btnJoinRoom_Click"/>

    </StackPanel>
</Page>